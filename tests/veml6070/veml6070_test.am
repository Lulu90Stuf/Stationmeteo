// veml6070_test.am — validation matérielle du VEML6070 (capteur UV)
// sur I2C bus 1. Pas de driver dédié dans amalgame-hardware-sensor
// pour l'instant, donc protocole écrit à la main avec I2c.WriteByte /
// I2c.ReadByte (voir ../../docs/cablage-veml6070.md pour le câblage).
//
// Le VEML6070 n'a pas de registre d'identification (contrairement au
// BME280) : deux adresses fixes en silicium, 0x38 (écriture commande
// + lecture LSB) et 0x39 (lecture MSB). La présence ne peut être
// confirmée que par un ACK sur ces deux adresses (scan I2C) — pas par
// un chip-id.
//
// Test de connectivité / réponse brute, PAS un driver calibré : la
// valeur "UV raw counts" n'est pas convertie en indice UV (ça demande
// les constantes de calibration du datasheet, hors scope ici). Le
// but est de vérifier que le câblage est bon et que les comptes
// bougent si on éclaire/couvre le capteur.
//
//   amc package add hardware-gpio
//   amc build veml6070_test.am -o veml6070_test
//   sudo ./veml6070_test

namespace Demo

import Amalgame.Hardware

public class Program {
    private static string Hex2(v: int) {
        let digits: string = "0123456789abcdef"
        let hi: int = (v / 16) % 16
        let lo: int = v % 16
        return String_Substring(digits, hi, 1) + String_Substring(digits, lo, 1)
    }

    public static void Main(string[] args) {
        let bus: I2c = new I2c(1)
        if (!bus.IsOpen()) {
            Console.WriteLine("I2C bus /dev/i2c-1 not open (permissions? interface disabled?)")
            return
        }

        Console.WriteLine("I2C scan:")
        let found: List<int> = bus.Scan()
        for addr in found {
            Console.WriteLine("  found 0x" + Program.Hex2(addr))
        }

        // Command register: 0x02 is the datasheet-documented minimum —
        // reserved bit 1 must always be set to 1, SD (shutdown) = 0
        // (device active), integration time left at its power-on
        // default. Double-check the VEML6070 app note's command-byte
        // table if you need a specific integration time for a
        // calibrated UV index later — this value is only meant to
        // wake the sensor up for a connectivity test.
        let cmdOk: bool = bus.WriteByte(0x38, 0x02)
        if (!cmdOk) {
            Console.WriteLine("failed to write command register at 0x38 — wiring?")
            bus.Close()
            return
        }

        // Datasheet: allow at least one integration cycle before the
        // first read. Loop a few reads 500ms apart so you can see the
        // raw count move if you wave a hand / UV source over the
        // sensor.
        var i: int = 0
        while (i < 6) {
            Process_Sleep(500)
            let lsb: int = bus.ReadByte(0x38)
            let msb: int = bus.ReadByte(0x39)
            if (lsb < 0 || msb < 0) {
                Console.WriteLine("read error (lsb=" + String_FromInt(lsb) + " msb=" + String_FromInt(msb) + ")")
            } else {
                let uvRaw: int = (msb * 256) + lsb
                Console.WriteLine("UV raw counts: " + String_FromInt(uvRaw))
            }
            i = i + 1
        }

        bus.Close()
    }
}
