// bme280_test.am — validation matérielle du BME280 sur I2C bus 1.
//
// Scanne le bus, puis lit température/pression/humidité si un BME280
// répond. Utile pour valider le câblage (voir ../../docs/cablage-bme280.md)
// avant d'intégrer le capteur dans le service capture/.
//
//   amc package add hardware-gpio hardware-sensor
//   amc build bme280_test.am -o bme280_test
//   sudo ./bme280_test        # sudo ou groupe i2c/gpio

namespace Demo

import Amalgame.Hardware
import Amalgame.Hardware.Sensor

public class Program {
    private static string Hex2(v: int) {
        let digits: string = "0123456789abcdef"
        let hi: int = (v / 16) % 16
        let lo: int = v % 16
        return String_Substring(digits, hi, 1) + String_Substring(digits, lo, 1)
    }

    public static void Main(string[] args) {
        let bus: I2c = new I2c(1)
        if (!bus.IsOpen()) {
            Console.WriteLine("I2C bus /dev/i2c-1 not open (permissions? interface disabled?)")
            return
        }

        Console.WriteLine("I2C scan:")
        let found: List<int> = bus.Scan()
        for addr in found {
            Console.WriteLine("  found 0x" + Program.Hex2(addr))
        }

        // Adresse validée sur notre module Bluedot : 0x77 (SD0 câblé
        // côté VCC). Si ton module a SD0 côté GND, ce sera 0x76.
        let env: Bme280 = new Bme280(bus, 0x77)
        if (!env.IsPresent()) {
            Console.WriteLine("BME280 not detected at 0x77")
            bus.Close()
            return
        }

        env.Read()
        Console.WriteLine("Temperature: " + String_FromInt(env.TempCenti()) + " (C x100)")
        Console.WriteLine("Pressure:    " + String_FromInt(env.PressurePa()) + " (Pa)")
        Console.WriteLine("Humidity:    " + String_FromInt(env.HumidityMilli()) + " (% x1000)")

        bus.Close()
    }
}
